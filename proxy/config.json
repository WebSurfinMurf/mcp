{
  "mcpProxy": {
    "addr": ":9090",
    "baseURL": "http://localhost:9090",
    "name": "Local MCP Proxy",
    "type": "streamable-http",
    "options": {
      "logEnabled": true,
      "panicIfInvalid": false
    }
  },
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@0.6.2", "/workspace"],
      "env": {
        "NODE_NO_WARNINGS": "1"
      }
    },
    "postgres": {
      "command": "/wrappers/postgres-wrapper.sh",
      "args": []
    },
    "playwright": {
      "command": "/wrappers/playwright-wrapper.sh",
      "args": []
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@2025.9.25"],
      "env": {
        "NODE_NO_WARNINGS": "1"
      }
    },
    "minio": {
      "command": "/wrappers/minio-wrapper.sh",
      "args": []
    },
    "n8n": {
      "command": "/wrappers/n8n-wrapper.sh",
      "args": []
    },
    "timescaledb": {
      "command": "/wrappers/timescaledb-wrapper.sh",
      "args": []
    },
    "ib": {
      "command": "/wrappers/ib-wrapper.sh",
      "args": []
    },
    "arangodb": {
      "command": "npx",
      "args": ["-y", "arango-server"],
      "env": {
        "NODE_NO_WARNINGS": "1",
        "ARANGO_URL": "http://arangodb:8529",
        "ARANGO_DB": "ai_memory",
        "ARANGO_USERNAME": "root",
        "ARANGO_PASSWORD": "4SlfiYq6XOUZWP7jKakBksrudBhSWIqV"
      }
    },
    "openmemory": {
      "command": "/wrappers/openmemory-wrapper.sh",
      "args": []
    }
  }
}
